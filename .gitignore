# ignore these files and folders from git tracking
# Dart-specific
.dart_tool/        # Generated by Dart tools (pub, build_runner, etc.)
.packages          # Package resolution file (deprecated but may appear)
build/             # Output from build_runner or other build tools

# IDEs
.idea/             # IntelliJ/Android Studio project files
.vscode/           # VS Code settings
*.iml              # IntelliJ module files

# OS-specific
.DS_Store          # macOS Finder metadata
Thumbs.db          # Windows Explorer metadata

# Logs & temp
*.log
*.tmp

# Coverage reports
coverage/

# Generated docs
doc/api/

# AI agent related files
memory
# Ignore all Markdown files
*.md
# But keep README.md tracked
!README.md
