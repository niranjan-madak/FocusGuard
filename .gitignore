# ignore these files and folders from git tracking
# MadakLabs framework file
MadakLabs_SDLC_Master_Briefing.docx
# AI agent related files
/memory
/aiagent-generated-artifacts
/Snapshots

# Package resolution file (deprecated but may appear)
.packages


# IDEs
# IntelliJ/Android Studio project files
.idea/
# VS Code settings
.vscode/
# IntelliJ module files
*.iml

# OS-specific
# macOS Finder metadata
.DS_Store
# Windows Explorer metadata
Thumbs.db

# Logs & temp
*.log
*.tmp

# Coverage reports
coverage/

# Generated docs
doc/api/

# AI agent related files
/memory
/aiagent-generated-artifacts
/Snapshots
# Ignore all Markdown files
*.md
# But keep README.md tracked
!README.md

# Output from build_runner or other build tools
/build

# Dart-specific
# Generated by Dart tools (pub, build_runner, etc.)
/.dart_tool

# Security — signing credentials and secrets (SR-009)
.env
*.keystore
*.jks
*.p12
*.pfx
key.properties
GoogleService-Info.plist
google-services.json
build/symbols/

