{
  "name": "focusguard",
  "version": "1.0.0",
  "description": "Deep Work Focus Timer — 75-minute sessions with 20-minute breaks",
  "main": "main.js",
  "author": "FocusGuard",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "setup:fonts": "node scripts/download-fonts.js",
    "dist": "electron-builder --publish never",
    "dist:win": "electron-builder --win --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:linux": "electron-builder --linux --publish never",
    "pack": "electron-builder --dir --publish never"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.0.0"
  },
  "overrides": {
    "glob": "^10.4.5",
    "tar": "^7.4.3"
  },
  "build": {
    "appId": "com.focusguard.app",
    "productName": "FocusGuard",
    "copyright": "Copyright © 2024 FocusGuard",
    "icon": "assets/icon.png",
    "asar": true,
    "asarUnpack": ["assets/**"],
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*",
      "!**/node_modules/.cache/**"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64", "ia32"] }
      ],
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FocusGuard",
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.productivity",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "icon": "assets/icon.png",
      "category": "Utility",
      "synopsis": "Deep Work Focus Timer",
      "description": "Interval-based focus timer using 75-minute work sessions and 20-minute breaks"
    },
    "deb": {
      "depends": ["libnotify4", "libxtst6", "libnss3"]
    }
  }
}
